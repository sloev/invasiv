# openFrameworks standard ignores
bin/*
!bin/data/
obj/
*.o
*.obj
*.exe
*.app
*.so
*.dylib
*.dll
*.la
*.lai
*.lo
*.slo
*.d
*.gch
*.pch
*.suo
*.user
*.ncb
*.sdf
*.sln
*.vcproj
*.vcxproj
*.filters
*.xcodeproj
*.xcworkspace

# Project Specific Folders (Usage oriented)
**/media/
**/media2/
**/configs/
settings.json

# Build and Release artifacts
artifacts/
!artifacts/.gitkeep
release/

# Testing
# Do NOT ignore the testing suite itself
!tests/
# But ignore any artifacts created during testing
tests/test_project/
tests/unit_tests
tests/*.tmp

# IDEs
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Temporary files
*.tmp
*.log
GEMINI.md
